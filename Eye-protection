# Main Application Window
# ----------------------------------------------------------------------
class EyeProtectionAlarm(QMainWindow):
    def __init__(
        self,
        timer_config: Optional[TimerConfig] = None,
        ui_config: Optional[UIConfig] = None,
        colors: Optional[ColorPalette] = None
    ) -> None:
        super().__init__()
        
        self._timer_config = timer_config or TimerConfig()
        self._ui_config = ui_config or UIConfig()
        self._colors = colors or ColorPalette()
        
        # Main timer state
        self._state = TimerState.RUNNING
        self._remaining_seconds = self._timer_config.work_duration_seconds
        
        # Usage timer (R.A.T.I.C)
        self._usage_seconds = 0
        self._usage_timer = QTimer(self)
        self._usage_timer.timeout.connect(self._update_usage_timer)
        
        # Window state
        self._is_minimized = False
        self._is_animating = False
        self._original_pos = QPoint()
        self._is_first_launch = True   # not really used anymore because all delays are same
        self._drag_offset = QPoint()
        
        # Components
        self._audio_manager = AudioManager()
        
        # UI elements
        self._progress_bar: CircularProgress
        self._time_display: QLabel
        self._status_label: QLabel
        self._usage_label: QLabel
        self._pause_btn: QPushButton
        self._reset_btn: QPushButton
        self._ratic_btn: QPushButton
        self._tray_icon: QSystemTrayIcon
        
        # Animations
        self._slide_anim: QPropertyAnimation
        self._progress_anim: QPropertyAnimation
        
        # Timers
        self._countdown_timer: QTimer
        self._auto_hide_timer: QTimer
        self._clock_timer: QTimer
        
        # Build UI
        self._setup_window()
        self._setup_ui()
        self._setup_animations()
        self._setup_tray_icon()
        self._setup_timers()
        
        # Start usage timer if initial state is RUNNING
        self._start_usage_timer()
        
        logger.info("صحبك ابو العنين initialized")

    # ------------------------------------------------------------------
    # Setup
    # ------------------------------------------------------------------
    def _setup_window(self) -> None:
        self.setWindowTitle("صحبك ابو العنين🤓")
        self.setFixedSize(self._ui_config.window_width, self._ui_config.window_height)
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        
        # Center on screen
        screen = QApplication.primaryScreen().geometry()
        self._original_pos = QPoint(
            (screen.width() - self._ui_config.window_width) // 2,
            (screen.height() - self._ui_config.window_height) // 2
        )
        self.move(self._original_pos)

    def _setup_ui(self) -> None:
        container = QWidget()
        container.setObjectName("Container")
        container.setStyleSheet(self._get_container_style())
        
        shadow = QGraphicsDropShadowEffect(self)
        shadow.setBlurRadius(40)
        shadow.setOffset(0, 10)
        shadow.setColor(QColor(0, 0, 0, 200))
        container.setGraphicsEffect(shadow)
        self.setCentralWidget(container)

        layout = QVBoxLayout(container)
        layout.setContentsMargins(30, 25, 30, 30)
        layout.setSpacing(8)

        layout.addLayout(self._create_header())
        
        self._time_display = self._create_time_display()
        layout.addWidget(self._time_display)

        self._progress_bar = CircularProgress(
            total_seconds=self._timer_config.work_duration_seconds,
            colors=self._colors
        )
        layout.addWidget(self._progress_bar, 0, Qt.AlignCenter)

        layout.addLayout(self._create_buttons())
        
        self._usage_label = self._create_usage_label()
        layout.addWidget(self._usage_label)
        
        self._status_label = self._create_status_label()
        layout.addWidget(self._status_label)

    def _get_container_style(self) -> str:
        return f"""
            #Container {{
                background: qlineargradient(
                    x1:0, y1:0, x2:1, y2:1,
                    stop:0 {self._colors.bg_gradient_start},
                    stop:1 {self._colors.bg_gradient_end}
                );
                border-radius: {self._ui_config.border_radius}px;
                border: 2px solid {self._colors.border_color};
            }}
        """

    def _create_header(self) -> QHBoxLayout:
        header = QHBoxLayout()
        title = QLabel("صحبك ابو العنين 🤓")
        title.setStyleSheet(f"""
            color: {self._colors.text_secondary};
            font-weight: bold;
            letter-spacing: 1px;
            font-size: 14px;
        """)
        close_btn = QPushButton("✕")
        close_btn.setFixedSize(34, 34)
        close_btn.setCursor(Qt.PointingHandCursor)
        close_btn.setToolTip("Minimize to tray")
        close_btn.setStyleSheet(f"""
            QPushButton {{
                background: {self._colors.border_color};
                color: white;
                border-radius: 17px;
                border: none;
                font-size: 14px;
            }}
            QPushButton:hover {{
                background: {self._colors.btn_danger};
            }}
        """)
        close_btn.clicked.connect(self._hide_window)

        header.addWidget(title)
        header.addStretch()
        header.addWidget(close_btn)
        return header

    def _create_time_display(self) -> QLabel:
        label = QLabel()
        label.setAlignment(Qt.AlignCenter)
        label.setStyleSheet(f"""
            color: {self._colors.text_accent};
            font-size: 24px;
            font-weight: 900;
            margin: 5px 0;
        """)
        return label

    def _create_buttons(self) -> QHBoxLayout:
        layout = QHBoxLayout()
        layout.setSpacing(12)
        
        self._reset_btn = QPushButton("RESET")
        self._reset_btn.setFixedSize(
            self._ui_config.button_width,
            self._ui_config.button_height
        )
        self._reset_btn.setCursor(Qt.PointingHandCursor)
        self._reset_btn.setToolTip("Reset the eye timer to 20 minutes")
        self._reset_btn.setStyleSheet(self._get_button_style(self._colors.btn_success))
        self._reset_btn.clicked.connect(self._reset_timer)
        # Connect reset button to reset auto-hide timer
        self._reset_btn.clicked.connect(self._reset_auto_hide)

        self._pause_btn = QPushButton("PAUSE")
        self._pause_btn.setFixedSize(
            self._ui_config.button_width,
            self._ui_config.button_height
        )
        self._pause_btn.setCursor(Qt.PointingHandCursor)
        self._pause_btn.setToolTip("Pause/Resume the eye timer")
        self._pause_btn.setStyleSheet(self._get_button_style(self._colors.btn_warning))
        self._pause_btn.clicked.connect(self._toggle_pause)
        self._pause_btn.clicked.connect(self._reset_auto_hide)

        self._ratic_btn = QPushButton("R.A.T.I.C")
        self._ratic_btn.setFixedSize(
            self._ui_config.button_width,
            self._ui_config.button_height
        )
        self._ratic_btn.setCursor(Qt.PointingHandCursor)
        self._ratic_btn.setToolTip("Reset the usage timer (computer active time) to zero")
        self._ratic_btn.setStyleSheet(self._get_button_style(self._colors.btn_info))
        self._ratic_btn.clicked.connect(self._reset_usage_timer)
        self._ratic_btn.clicked.connect(self._reset_auto_hide)

        layout.addWidget(self._reset_btn)
        layout.addWidget(self._pause_btn)
        layout.addWidget(self._ratic_btn)
        return layout

    def _get_button_style(self, color: str) -> str:
        return f"""
            QPushButton {{
                background: {color};
                color: {self._colors.btn_text};
                border-radius: {self._ui_config.button_radius}px;
                font-weight: 900;
                font-size: 13px;
                border: none;
            }}
            QPushButton:hover {{
                background: white;
            }}
            QPushButton:pressed {{
                background: {color};
                opacity: 0.8;
            }}
            QPushButton:disabled {{
                background: {self._colors.btn_disabled_bg};
                color: {self._colors.btn_disabled_text};
            }}
        """

    def _create_usage_label(self) -> QLabel:
        label = QLabel("Active time: 00:00:00")
        label.setAlignment(Qt.AlignCenter)
        label.setStyleSheet(f"""
            color: {self._colors.text_accent};
            font-size: 16px;
            font-weight: bold;
            margin-top: 5px;
            padding: 8px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 12px;
        """)
        label.setToolTip("Total time you've been active (timer running)")
        return label

    def _create_status_label(self) -> QLabel:
        label = QLabel("MONITORING ACTIVE")
        label.setAlignment(Qt.AlignCenter)
        label.setStyleSheet(f"""
            color: {self._colors.text_muted};
            font-weight: bold;
            font-size: 11px;
            margin-top: 8px;
        """)
        return label

    def _setup_animations(self) -> None:
        self._slide_anim = QPropertyAnimation(self, b"pos")
        self._slide_anim.setDuration(self._timer_config.animation_duration_ms)
        self._slide_anim.setEasingCurve(QEasingCurve.OutExpo)
        self._slide_anim.finished.connect(self._on_slide_finished)

        self._progress_anim = QPropertyAnimation(self._progress_bar, b"progress")
        self._progress_anim.setDuration(self._timer_config.progress_animation_ms)
        self._progress_anim.setEasingCurve(QEasingCurve.InOutQuad)

    def _setup_timers(self) -> None:
        self._countdown_timer = QTimer(self)
        self._countdown_timer.timeout.connect(self._update_countdown)
        
        self._auto_hide_timer = QTimer(self)
        self._auto_hide_timer.setSingleShot(True)
        self._auto_hide_timer.timeout.connect(self._hide_window)

        self._clock_timer = QTimer(self)
        self._clock_timer.timeout.connect(self._update_clock)
        self._clock_timer.start(self._timer_config.clock_update_interval_ms)
        
        self._update_clock()
        self._countdown_timer.start(self._timer_config.countdown_interval_ms)

