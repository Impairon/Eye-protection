# ----------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------
@dataclass(frozen=True)
class TimerConfig:
    """Configuration for timer durations and intervals."""
    
    work_duration_minutes: int = 20
    auto_hide_delay_ms: int = 2500         
    animation_duration_ms: int = 500
    progress_animation_ms: int = 900
    clock_update_interval_ms: int = 1000
    countdown_interval_ms: int = 1000
    
    @property
    def work_duration_seconds(self) -> int:
        """Total work duration in seconds."""
        return self.work_duration_minutes * 60


@dataclass(frozen=True)
class UIConfig:
    """Configuration for UI dimensions and styling."""
    
    window_width: int = 700                 
    window_height: int = 680                
    window_margin: int = 20
    progress_size: int = 200
    progress_stroke_width: int = 12
    border_radius: int = 30
    button_height: int = 48
    button_width: int = 140
    button_radius: int = 24


@dataclass(frozen=True)
class ColorPalette:
    """Application color palette."""
    
    bg_gradient_start: str = "#2a2a3e"
    bg_gradient_end: str = "#161625"
    border_color: str = "#32324d"
    progress_track: tuple[int, int, int, int] = (45, 45, 65, 180)
    progress_start: str = "#4cd137"
    progress_end: str = "#2196f3"
    text_primary: str = "#ffffff"
    text_secondary: str = "#a0a0c0"
    text_muted: str = "#57606f"
    text_accent: str = "#4cd137"
    btn_success: str = "#4cd137"
    btn_warning: str = "#f1c40f"
    btn_danger: str = "#ff4757"
    btn_info: str = "#3498db"
    btn_disabled_bg: str = "#2f3542"
    btn_disabled_text: str = "#57606f"
    btn_text: str = "#1e1e2f"


class TimerState(Enum):
    RUNNING = auto()
    PAUSED = auto()
    ALARM = auto()
    IDLE = auto()


# ----------------------------------------------------------------------
# Circular Progress Widget
# ----------------------------------------------------------------------
class CircularProgress(QWidget):
    def __init__(
        self,
        parent: Optional[QWidget] = None,
        size: int = UIConfig.progress_size,
        stroke_width: int = UIConfig.progress_stroke_width,
        total_seconds: int = TimerConfig().work_duration_seconds,
        colors: Optional[ColorPalette] = None
    ) -> None:
        super().__init__(parent)
        self._value: float = 100.0
        self._size = size
        self._stroke_width = stroke_width
        self._total_seconds = total_seconds
        self._colors = colors or ColorPalette()
        self.setFixedSize(size, size)
        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Fixed)

    def setValue(self, value: float) -> None:
        clamped_value = max(0.0, min(100.0, value))
        if self._value != clamped_value:
            self._value = clamped_value
            self.update()

    def value(self) -> float:
        return self._value

    def setTotalSeconds(self, seconds: int) -> None:
        self._total_seconds = seconds
        self.update()

    def paintEvent(self, event) -> None:
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing, True)
        padding = self._stroke_width // 2 + 4
        rect = self.rect().adjusted(padding, padding, -padding, -padding)

        # Background track
        pen = QPen()
        pen.setWidth(self._stroke_width)
        pen.setColor(QColor(*self._colors.progress_track))
        pen.setCapStyle(Qt.RoundCap)
        painter.setPen(pen)
        painter.drawEllipse(rect)

        # Progress arc
        if self._value > 0:
            gradient = QLinearGradient(rect.topLeft(), rect.bottomRight())
            gradient.setColorAt(0, QColor(self._colors.progress_start))
            gradient.setColorAt(1, QColor(self._colors.progress_end))
            pen.setBrush(QBrush(gradient))
            painter.setPen(pen)
            start_angle = 90 * 16
            span_angle = -int(360 * 16 * (self._value / 100))
            painter.drawArc(rect, start_angle, span_angle)

        # Center text
        total_seconds = int((self._value / 100) * self._total_seconds)
        minutes, seconds = divmod(total_seconds, 60)
        time_text = f"{minutes:02d}:{seconds:02d}"
        font = QFont("Segoe UI", 20, QFont.Bold)
        painter.setFont(font)
        painter.setPen(QColor(self._colors.text_primary))
        painter.drawText(self.rect(), Qt.AlignCenter, time_text)

    @pyqtProperty(float)
    def progress(self) -> float:
        return self._value

    @progress.setter
    def progress(self, value: float) -> None:
        self.setValue(value)


# ----------------------------------------------------------------------
# Audio Manager (not used for alarm but kept for potential future use)
# ----------------------------------------------------------------------
class AudioManager:
    def __init__(self, sound_file: str = "alarmclock.wav") -> None:
        self._sound_file = Path(sound_file)
        self._initialized = False
        self._initialize_audio()

    def _initialize_audio(self) -> None:
        try:
            pygame.mixer.init(frequency=44100, size=-16, channels=2, buffer=512)
            self._initialized = True
        except pygame.error as e:
            logger.warning(f"Audio init failed: {e}")

    def play_alarm(self) -> None:
        if not self._initialized:
            return
        try:
            if self._sound_file.exists():
                pygame.mixer.music.load(str(self._sound_file))
                pygame.mixer.music.play()
        except Exception as e:
            logger.error(f"Playback error: {e}")

    def stop(self) -> None:
        if self._initialized:
            try:
                pygame.mixer.music.stop()
            except:
                pass

    def cleanup(self) -> None:
        if self._initialized:
            try:
                pygame.mixer.quit()
            except:
                pass


