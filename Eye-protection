    # ------------------------------------------------------------------
    # Auto‑hide reset logic
    # ------------------------------------------------------------------
    def _reset_auto_hide(self) -> None:
        """Reset the auto‑hide timer: cancel current and start fresh."""
        if self._state in (TimerState.ALARM, TimerState.PAUSED):
            return  # Do not auto‑hide when alarm or paused
        if self.isVisible() and not self._is_minimized:
            self._auto_hide_timer.stop()
            self._auto_hide_timer.start(self._timer_config.auto_hide_delay_ms)
            logger.debug("Auto‑hide timer reset")

    # ------------------------------------------------------------------
    # Usage Timer (R.A.T.I.C) Logic
    # ------------------------------------------------------------------
    def _start_usage_timer(self) -> None:
        if self._state == TimerState.RUNNING and not self._usage_timer.isActive():
            self._usage_timer.start(1000)

    def _stop_usage_timer(self) -> None:
        if self._usage_timer.isActive():
            self._usage_timer.stop()

    def _update_usage_timer(self) -> None:
        if self._state == TimerState.RUNNING:
            self._usage_seconds += 1
            self._update_usage_display()
        else:
            self._stop_usage_timer()

    def _update_usage_display(self) -> None:
        hours = self._usage_seconds // 3600
        minutes = (self._usage_seconds % 3600) // 60
        seconds = self._usage_seconds % 60
        self._usage_label.setText(f"Active time: {hours:02d}:{minutes:02d}:{seconds:02d}")

    def _reset_usage_timer(self) -> None:
        self._usage_seconds = 0
        self._update_usage_display()
        logger.info("R.A.T.I.C reset to zero")

    # ------------------------------------------------------------------
    # Main Timer Logic
    # ------------------------------------------------------------------
    def _update_countdown(self) -> None:
        if self._state != TimerState.RUNNING:
            return

        if self._remaining_seconds > 0:
            self._remaining_seconds -= 1
            percent = (self._remaining_seconds / self._timer_config.work_duration_seconds) * 100
            self._progress_bar.setValue(percent)
            
            minutes, seconds = divmod(self._remaining_seconds, 60)
            self._tray_icon.setToolTip(
                f"صحبك ابو العنين\nTime remaining: {minutes:02d}:{seconds:02d}\nClick to toggle"
            )
        else:
            self._trigger_alarm()

    def _trigger_alarm(self) -> None:
        self._state = TimerState.ALARM
        self._countdown_timer.stop()
        self._progress_bar.setValue(0)
        self._stop_usage_timer()
        
        self._status_label.setText("👁️ protect your eyes pro 👁️\n" \
        "  __________\n" \
        " /                    \\\n" \
        "  ----------------")
        self._status_label.setStyleSheet(f"""
            color: {self._colors.btn_success};
            font-weight: bold;
            font-size: 16px;
            margin-top: 10px;
            padding: 10px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
        """)
        
        self.setWindowFlags(self.windowFlags() | Qt.WindowStaysOnTopHint)
        self._restore_window(auto_hide=False)
        
        self._pause_btn.setEnabled(False)
        self._tray_icon.setToolTip("🔔 صحبك ابو العنين - Time to rest your eyes!\nprotect your eyes pro 👁️")
        
        logger.info("Alarm triggered")

    def _reset_timer(self) -> None:
        self._auto_hide_timer.stop()
        
        self._remaining_seconds = self._timer_config.work_duration_seconds
        self._is_first_launch = False
        
        if self._state == TimerState.ALARM:
            self._state = TimerState.RUNNING
            self._pause_btn.setEnabled(True)
            self._pause_btn.setText("PAUSE")
        
        if self._state == TimerState.PAUSED:
            self._status_label.setText("⏸ PAUSED")
            self._status_label.setStyleSheet(f"""
                color: {self._colors.btn_warning};
                font-weight: bold;
                font-size: 14px;
                margin-top: 10px;
            """)
            self._countdown_timer.stop()
        else:
            self._status_label.setText("MONITORING ACTIVE")
            self._status_label.setStyleSheet(f"""
                color: {self._colors.text_muted};
                font-weight: bold;
                font-size: 11px;
                margin-top: 10px;
            """)
            self._countdown_timer.stop()
            self._countdown_timer.start(self._timer_config.countdown_interval_ms)
            self._start_usage_timer()
        
        self._progress_bar.setValue(100)
        self.setWindowFlags(self.windowFlags() & ~Qt.WindowStaysOnTopHint)
        self.show()
        
        if self._state != TimerState.PAUSED:
            self._start_auto_hide()
        
        self._tray_icon.setToolTip("صحبك ابو العنين - Click to toggle")
        self._audio_manager.stop()
        
        logger.info("Timer reset")

    def _toggle_pause(self) -> None:
        if self._state == TimerState.ALARM:
            return
            
        if self._state == TimerState.PAUSED:
            self._state = TimerState.RUNNING
            self._pause_btn.setText("PAUSE")
            self._status_label.setText("MONITORING ACTIVE")
            self._status_label.setStyleSheet(f"""
                color: {self._colors.text_muted};
                font-weight: bold;
                font-size: 11px;
                margin-top: 10px;
            """)
            self._countdown_timer.start(self._timer_config.countdown_interval_ms)
            self._start_usage_timer()
            if self.isVisible() and not self._is_minimized:
                self._start_auto_hide()
            logger.info("Timer resumed")
        else:
            self._state = TimerState.PAUSED
            self._pause_btn.setText("RESUME")
            self._status_label.setText("⏸ PAUSED")
            self._status_label.setStyleSheet(f"""
                color: {self._colors.btn_warning};
                font-weight: bold;
                font-size: 14px;
                margin-top: 10px;
            """)
            self._countdown_timer.stop()
            self._stop_usage_timer()
            self._auto_hide_timer.stop()
            logger.info("Timer paused")

    def _update_clock(self) -> None:
        self._time_display.setText(QTime.currentTime().toString("hh:mm:ss AP"))

    # ------------------------------------------------------------------
    # Window Management
    # ------------------------------------------------------------------
    def _toggle_window(self) -> None:
        if self.isVisible() and not self._is_minimized:
            self._hide_window()
        else:
            self._restore_window(auto_hide=True)
            self.raise_()
            self.activateWindow()
            self.setWindowState(self.windowState() & ~Qt.WindowMinimized)
            self._reset_auto_hide()

    def _on_tray_activated(self, reason: QSystemTrayIcon.ActivationReason) -> None:
        if reason in (QSystemTrayIcon.Trigger, QSystemTrayIcon.DoubleClick):
            self._toggle_window()

    def _on_slide_finished(self) -> None:
        self._is_animating = False
        if self._is_minimized:
            self.hide()

    def _hide_window(self) -> None:
        if self._is_animating:
            return
        self._auto_hide_timer.stop()
        self._original_pos = self.pos()
        self._is_animating = True
        self._is_minimized = True
        target_y = self.pos().y() + self.height() + 50
        self._slide_anim.setStartValue(self.pos())
        self._slide_anim.setEndValue(QPoint(self.pos().x(), target_y))
        self._slide_anim.start()

    def _restore_window(self, auto_hide: bool = True) -> None:
        self.show()
        if self._is_animating:
            self._slide_anim.stop()
        self._is_minimized = False
        self._is_animating = True
        self._slide_anim.setStartValue(self.pos())
        self._slide_anim.setEndValue(self._original_pos)
        self._slide_anim.start()
        if auto_hide and self._state not in (TimerState.ALARM, TimerState.PAUSED):
            self._start_auto_hide()

    def _start_auto_hide(self) -> None:
        if self._state not in (TimerState.ALARM, TimerState.PAUSED) and self.isVisible():
            delay = self._timer_config.auto_hide_delay_ms
            self._auto_hide_timer.start(delay)

    def showEvent(self, event) -> None:
        super().showEvent(event)
        if not self._is_minimized and not self._auto_hide_timer.isActive():
            self._start_auto_hide()

    # ------------------------------------------------------------------
    # Mouse Events for Dragging & Resetting Auto‑Hide
    # ------------------------------------------------------------------
    def mousePressEvent(self, event) -> None:
        if event.button() == Qt.LeftButton:
            # Reset auto‑hide on any click inside the window
            self._reset_auto_hide()
            if event.pos().y() < 60:
                self._drag_offset = event.pos()

    def mouseMoveEvent(self, event) -> None:
        if not self._drag_offset.isNull():
            new_pos = self.mapToGlobal(event.pos() - self._drag_offset)
            self.move(new_pos)
            if not self._is_minimized:
                self._original_pos = new_pos

    def mouseReleaseEvent(self, event) -> None:
        self._drag_offset = QPoint()

    # ------------------------------------------------------------------
    # Cleanup
    # ------------------------------------------------------------------
    def _quit_application(self) -> None:
        self._usage_timer.stop()
        self._audio_manager.cleanup()
        self._tray_icon.hide()
        QApplication.quit()

    def closeEvent(self, event) -> None:
        event.ignore()
        self._hide_window()


# ----------------------------------------------------------------------
# Application Entry Point
# ----------------------------------------------------------------------
def main() -> int:
    QApplication.setAttribute(Qt.AA_EnableHighDpiScaling, True)
    QApplication.setAttribute(Qt.AA_UseHighDpiPixmaps, True)
    
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    app.setQuitOnLastWindowClosed(False)
    
    window = EyeProtectionAlarm()
    window.show()
    
    return app.exec_()


if __name__ == "__main__":
    sys.exit(main())
